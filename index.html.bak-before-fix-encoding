        const SPHERE_IMAGES = (cfg.sphereImages && cfg.sphereImages.length) ? cfg.sphereImages : [];
        const SP_RADIUS = 6, SP_ROWS = 6, SP_POLAR_MARGIN = 0.15;
        const SP_INTRO_RADIUS = 16, SP_INTRO_DURATION_MS = 2800, SP_INTRO_STAGGER_MS = 900;
