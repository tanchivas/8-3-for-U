        const enableMorphEffect = cfg.enableMorphEffect !== false;  // default: báº­t
        const enableSphere      = cfg.enableSphere !== false;       // default: báº­t
        const enableSphereFlyingImages = cfg.enableSphereFlyingImages !== false; // default: báº­t
        const enableLetter      = cfg.enableLetter !== false;       // default: báº­t
        const enableWebsiteInfo = cfg.enableWebsiteInfo !== false;  // default: báº­t
        const autoSphereFlow    = false;
        const autoOpenLetter    = false;

        let scene, camera, renderer, controls, clock;
        let composer, bloomPass; 

        let particlesGeometry, particlesMaterial, particleSystem;
        let backgroundParticleSystem = null, backgroundParticlesGeometry = null, backgroundParticlesMaterial = null;
        let backgroundSourcePositions = null;
        let currentPositions, sourcePositions, targetPositions; 
        let particleSizes, particleOpacities, particleEffectStrengths; 
        let noise3D, noise4D; 

        let isInitialized = false;

        const isDesktop = typeof window !== 'undefined' && window.innerWidth >= 768;
        const CONFIG = {
            particleCount: 25000,
            imageParticleCount: 400000,
            textParticleCountMin: 6000,
            textParticleCountMax: 120000,
            textParticlesPerChar: 3500,
            shapeSize: 14,
